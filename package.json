{
  "name": "thepm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "thepm": "./bin/thepm.mjs",
    "thepm-bridge": "./bin/thepm-bridge.mjs"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:hub": "vite build",
    "build:binary": "esbuild src/bridge-cli.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/thepm-bridge.mjs --packages=external",
    "build:thepm": "vite build",
    "preview": "vite preview",
    "start": "node --import tsx server.ts",
    "thepm": "node bin/thepm.mjs",
    "test": "vitest run",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/adapter-vercel": "^5.10.3",
    "@sveltejs/kit": "^2.20.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/diff": "^5.2.0",
    "@types/ws": "^8.5.14",
    "esbuild": "^0.25.12",
    "rollup-plugin-visualizer": "^5.12.0",
    "svelte": "^5.20.0",
    "svelte-check": "^4.1.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.9.0",
    "@langchain/anthropic": "^0.3.14",
    "@langchain/community": "0.3.49",
    "@langchain/core": "^0.3.40",
    "@langchain/langgraph": "^0.2.60",
    "@langchain/openai": "^0.4.1",
    "@linear/sdk": "^31.0.0",
    "@supabase/supabase-js": "^2.49.1",
    "chokidar": "^4.0.0",
    "diff": "^5.2.0",
    "dotenv": "^16.4.0",
    "marked": "^16.0.0",
    "tsx": "^4.21.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  }
}
