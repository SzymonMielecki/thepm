LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-haiku-4-5

ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_STT_MODEL=scribe_v2_realtime

# Bridge (CLI): `--project-root` = one git repo for worktrees; repeat `--context-root` for more clones (frontend+backend).
# Delegation (hub; worktrees + tmux tabs are created on the bridge host)
# THEPM_WORKTREE_ROOT=/path/to/worktrees-parent
# THEPM_CLAUDE_BIN=claude
# Bridge-only: append --dangerously-skip-permissions to delegated Claude Code (teammates inherit). Use only on trusted worktrees.
# THEPM_CLAUDE_DANGEROUSLY_SKIP_PERMISSIONS=1
# cmux: open the delegated lead in a new workspace (new-window) vs a pane split (split-window). Default: workspace. Pane split: THEPM_CMUX_LEAD_SPAWN=split
# THEPM_CMUX_LEAD_SPAWN=workspace
# Team delegations inject CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1 on the bridge; override hub only if needed:
# CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1
# THEPM_MUX=auto
# cmux: use the claude-teams tmux shim so delegation hits cmux (not system tmux). Auto-picked when CMUX_SOCKET_PATH is set and ~/.cmuxterm/claude-teams-bin/tmux exists — see https://cmux.com/docs/agent-integrations/claude-code-teams
# THEPM_TMUX_BIN=/Users/you/.cmuxterm/claude-teams-bin/tmux
# If the bridge sees mux as "none", set the tmux session name (in the same env as the shim):
# THEPM_MUX_SESSION=my-session
# THEPM_DELEGATION_KEEP_WORKTREE=on_failure

# Linear (hub) — list issues / workflow in the UI; see LINEAR_API_KEY and LINEAR_TEAM_ID in your real .env
# In-memory response cache to reduce API rate limits (seconds). Defaults: 60s issue list pages, 600s states/users.
# LINEAR_CACHE_TTL_SECONDS=60
# LINEAR_CACHE_META_TTL_SECONDS=600
