# === Hub security (set for remote / Tailscale) ===
# If empty: a stable HUB_TOKEN is derived from the project directory (per repo when using `thepm`).
# Set HUB_TOKEN here or in a .env in your app project to use a custom secret. HUB_TOKEN_AUTO=off
# disables the derived token and leaves the hub open (no token required) when HUB_TOKEN is unset.
HUB_TOKEN=
# HUB_TOKEN_AUTO=off

# === LLM (anthropic | openai | ollama) ===
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Use ids from Anthropic docs (e.g. claude-haiku-4-5, claude-3-5-sonnet-20241022). Wrong names 404.
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
# Local Ollama (no cloud API key). Ensure `ollama serve` and `ollama pull <OLLAMA_MODEL>`.
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2

# === ElevenLabs streaming STT (scribe / speech-to-text) ===
ELEVENLABS_API_KEY=
# Override WebSocket URL if your product uses a different path than the default
# ELEVENLABS_STT_URL=wss://api.elevenlabs.io/...
ELEVENLABS_STT_MODEL=scribe_v1

# === Linear ===
LINEAR_API_KEY=
LINEAR_TEAM_ID=

# === Codebase / PRD ===
# The bridge is the code/PRD backend. Start `thepm bridge` from the repo you want the hub to manage.
# PROJECT_ROOT / PRD_PATH remain as hub-local defaults (token derivation and metadata display).
# PROJECT_ROOT=/path/to/your/app
# PRD_PATH=PRD.md
# THEPM_INVOCATION_CWD=   # usually unset; thepm wrapper sets it — do not set unless you know why

# LLM: auto-generate PRD.md from the repo when the bridge connects:
#   PRD_BOOTSTRAP=if_empty   (default) — only if file missing / stub; `always` to overwrite; `off` to disable
#   BRIDGE_PRD_BOOTSTRAP=…   (legacy alias, same as PRD_BOOTSTRAP)
# Run the bridge in the app repo:
#   thepm bridge --hub-url <...> --token <...> --project-root <repo> --prd <path-to-PRD.md> [--workspace <id>]
# CODE_BRIDGE_WORKSPACE_ID=default

# === Data ===
# DATABASE_PATH=./data/app.db
PORT=3000
HOST=0.0.0.0

# Public origin of the hub (for PWA / mobile or docs; optional for local-only)
# PUBLIC_HUB_URL=https://your-hub.example.com
