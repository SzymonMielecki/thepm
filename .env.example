# === Hub security (set for remote / Tailscale; optional locally) ===
HUB_TOKEN=

# === LLM (anthropic | openai | ollama) ===
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Use ids from Anthropic docs (e.g. claude-haiku-4-5, claude-3-5-sonnet-20241022). Wrong names 404.
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
# Local Ollama (no cloud API key). Ensure `ollama serve` and `ollama pull <OLLAMA_MODEL>`.
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2

# === ElevenLabs streaming STT (scribe / speech-to-text) ===
ELEVENLABS_API_KEY=
# Override WebSocket URL if your product uses a different path than the default
# ELEVENLABS_STT_URL=wss://api.elevenlabs.io/...
ELEVENLABS_STT_MODEL=scribe_v1

# === Linear ===
LINEAR_API_KEY=
LINEAR_TEAM_ID=

# === Codebase / PRD ===
# In local mode (default), the hub reads/writes this path ON THE HUB machine (the directory where you
# start `pnpm dev`, unless you set these). It is NOT “the other repo on your laptop” unless that path
# is reachable on this machine. To edit a different machine’s project + PRD, use `CODE_BACKEND=bridge`.
# PROJECT_ROOT=/path/to/your/app
# PRD_PATH=PRD.md

# When the hub runs in the cloud (or you want the PRD/tools on your dev box), set to `bridge` and run
# the bridge in the target repository (see `thepm-bridge --help`):
#   thepm-bridge --hub-url <HUB_WSS> --token <same as HUB_TOKEN> --project-root <repo> --prd <path-to-PRD.md> [--workspace <id>]
# Hub must have:
# CODE_BACKEND=bridge
# CODE_BRIDGE_WORKSPACE_ID=default

# === Data ===
# DATABASE_PATH=./data/app.db
PORT=3000
HOST=0.0.0.0

# Public origin of the hub (for PWA / mobile or docs; optional for local-only)
# PUBLIC_HUB_URL=https://your-hub.example.com
